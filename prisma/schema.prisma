generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Community {
  id          Int      @id @default(autoincrement())
  slug        String   @unique
  name        String
  type        String
  icon        String
  image       String
  description String
  members     Int      @default(0)
  discord     String
  roblox      String?
  about       String
  staff       Json?
  createdAt   DateTime @default(now())
  discordId   String?
  games       Game[]
}

model News {
  id        Int     @id @default(autoincrement())
  title     String
  slug      String  @unique
  content   String
  image     String?
  published Boolean @default(false)

  authorId Int?
  author   User? @relation(fields: [authorId], references: [id])

  createdAt DateTime @default(now())
}

model Event {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String
  image       String?
  date        String
  time        String
  discord     String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String
  image       String?
  platform    String
  status      String
  url         String?
  featured    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model Game {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String
  image       String?
  platform    String
  link        String?
  featured    Boolean @default(false)

  communityId Int?
  community   Community? @relation(fields: [communityId], references: [id])

  createdAt DateTime @default(now())
}

model Developer {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  role        String
  icon        String
  description String
  image       String?
  github      String?
  createdAt   DateTime @default(now())
}

model User {
  id        Int      @id @default(autoincrement())
  discordId String   @unique
  username  String
  image     String?
  bio       String?
  role      String   @default("USER")
  createdAt DateTime @default(now())

  news News[]
  logs AuditLog[]

  supportTickets  SupportTicket[]
  supportMessages SupportMessage[]
}

model AuditLog {
  id      Int    @id @default(autoincrement())
  action  String
  target  String
  details String
  userId  Int?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model SiteSettings {
  id Int @id @default(1)

  siteName    String  @default("Nexus")
  description String?

  logo    String?
  favicon String?

  discord String?
  github  String?
  youtube String?

  maintenance Boolean @default(false)

  updatedAt DateTime @updatedAt
}

model SupportTicket {
  id Int @id @default(autoincrement())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  subject  String
  category String
  status   String @default("OPEN")

  // Soft delete system
  deleted   Boolean   @default(false)
  deletedAt DateTime?
  deletedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages SupportMessage[]
}

model SupportMessage {
  id Int @id @default(autoincrement())

  ticketId Int
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  senderId Int?
  sender   User? @relation(fields: [senderId], references: [id])

  message String

  createdAt DateTime @default(now())
}

enum PartnerStatus {
  PENDING
  APPROVED
  REJECTED
}

model Partner {

  id Int @id @default(autoincrement())

  name String
  slug String @unique

  ownerName String
  email String

  logo String
  banner String?

  description String
  reason String

  members Int @default(0)

  discord String?
  roblox String?
  website String?

  socials String?

  featured Boolean @default(false)
  verified Boolean @default(true)

  tier String @default("Official")

  status PartnerStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}